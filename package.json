{
  "name": "h31d3nt0r",
  "version": "0.1.3",
  "private": true,
  "description": "Loopback HTTP bridge around @cursor/sdk so Hermes Agent (provider: custom) can chat through Cursor.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "verify-sdk": "tsx src/scripts/verify-sdk.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:integration": "RUN_CURSOR_INTEGRATION=1 vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.13",
    "@hono/node-server": "^2.0.3",
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
