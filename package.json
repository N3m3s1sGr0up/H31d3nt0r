{
  "name": "h31d3nt0r",
  "version": "0.3.0",
  "private": true,
  "description": "Loopback HTTP gateway: OpenAI Chat Completions API in front of @cursor/sdk.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "verify-sdk": "tsx src/scripts/verify-sdk.ts",
    "verify-client": "tsx src/scripts/verify-client.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:integration": "RUN_CURSOR_INTEGRATION=1 vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "version:bump": "tsx src/scripts/bump-version.ts",
    "version:verify": "tsx src/scripts/verify-version.ts"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.13",
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@tootallnate/once": "^2.0.3",
    "esbuild": "^0.28.1",
    "tar": "^7.5.15",
    "undici": "^6.26.0",
    "vite": "^6.4.2"
  }
}
