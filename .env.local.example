# Copy to `.env.local` beside package.json and IMMEDIATELY run:
#   chmod 600 .env.local
# Both values below are secrets. If you skip the chmod on a multi-user
# host they become world-readable; rotate both keys if that happens.
# .env.local is in .gitignore — do not commit it.

# Required: Cursor platform key the SDK uses to authenticate runs.
# Source: https://cursor.com/dashboard (User API key) or team service-account key.
CURSOR_API_KEY=

# Required: shared secret clients (Hermes, curl, automation) send as
# `Authorization: Bearer <BRIDGE_API_KEY>` to /v1/*.
# Generate with: openssl rand -hex 32
BRIDGE_API_KEY=

# Loopback bind only by default.
HOST=127.0.0.1
PORT=8787

# Working directory for Cursor SDK local runs.
# When unset, the bridge defaults to the parent directory of this checkout (monorepo-era layout).
# For standalone installs, pin the tree you want Composer to see:
# WORKSPACE_CWD=/path/to/your/project

# Hermes profile directory (second cwd for Cursor alongside repo root).
# HERMES_HOME=/home/you/.hermes

# Repo only (exclude ~/.hermes from Cursor cwd list):
# WORKSPACE_CWD_ONLY=1

# Hard cap on in-flight Cursor SDK runs. Each chat completion (stream or
# non-stream) takes one slot; at capacity, requests get 429 + Retry-After.
# Tune up if you have legitimate concurrent users; tune down on shared hosts.
MAX_AGENTS=4

# Timeouts (milliseconds; 0 disables that specific guard unless noted).

# Ceiling for POST /v1/chat/completions without stream (Agent.prompt). At timeout
# the bridge returns HTTP 504 `request_timeout` (retryable). The Cursor run may still
# finish briefly after the bridge gives up unless the SDK adds cooperative cancel there.
BRIDGE_CHAT_COMPLETION_MS=900000

# Wall clock for streaming responses after SSE headers flush. On expiry the bridge
# cancels `run.cancel()` (when supported) then emits SSE `bridge.error` with code
# `stream_wall_clock_timeout`, then `[DONE]`.
BRIDGE_CHAT_STREAM_MS=900000

# Budget for Agent.create + send before SSE starts. HTTP 504 `sdk_connect_timeout` on overrun.
BRIDGE_SDK_STREAM_CONNECT_MS=120000

# GET /ready calls Cursor.models.list under this deadline. Failures bubble as structured
# errors (timeouts map to upstream_unreachable via the shared SDK mapper).
# Use 0 to skip the Cursor cloud probe entirely (respond 200 ready with cursor_sdk=skipped).
BRIDGE_CURSOR_READY_MS=12000

# Periodic SSE `: comment` heartbeats mid-stream (`0` disables).
BRIDGE_SSE_HEARTBEAT_MS=15000

# Cursor SDK local agents: which on-disk setting layers to load (comma list).
# Leave unset for the historical default (none). Example:
#   CURSOR_LOCAL_SETTING_SOURCES=project,user
# CURSOR_LOCAL_SETTING_SOURCES=

# Optional JSON object passed as AgentOptions.mcpServers on every run.
# Escape carefully in .env.local or use systemd Environment= with a file.
# CURSOR_AGENT_MCP_SERVERS={"memory":{"type":"stdio","command":"/path/to/server","args":[]}}

# Optional override for the model used by `npm run verify-sdk`.
# SDK_VERIFY_MODEL=composer-2

# -----------------------------------------------------------------------------
# OPTIONAL: Hermes-native OpenAI tool_calls via HTTPS upstream proxy
#
# Hermes attaches JSON `tools` on gateway turns. When these knobs are configured,
# the bridge POSTs the OpenAI-compatible body to upstream `/v1/chat/completions`,
# yielding canonical `tool_calls` without Cursor HERMES_BRIDGE_TOOL_JSON coaxing.

# BRIDGE_CHAT_UPSTREAM_MODE=off   # allowed: off | tools | always
# BRIDGE_CHAT_UPSTREAM_URL=https://api.openai.com/v1/chat/completions
# BRIDGE_CHAT_UPSTREAM_API_KEY=
# If BRIDGE_CHAT_UPSTREAM_API_KEY is blank, OPENAI_API_KEY is used instead.
# OPENAI_API_KEY=
# Upstream handshake/response deadline (abort → bridge `upstream_timeout`)
# BRIDGE_CHAT_UPSTREAM_MS=120000

